{
    "compilerOptions": {
        "alwaysStrict": true,
        "target": "ES2020",
        "allowJs": true,
        "checkJs": true,
        "baseUrl": "./",
        "allowSyntheticDefaultImports": true,
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "ES2020",
        "moduleResolution": "node",
        "declaration": true
    },
    "include": ["src"],
    "exclude": ["node_modules"]
}